# =============================================================================
# AgentForge - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these in the Vercel Dashboard -> Settings -> Environment Variables
# =============================================================================

# Database (SQLite for development)
DATABASE_URL=file:./db/custom.db

# Google OAuth for Gemini CLI Integration
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Enable the "Generative Language API" at: https://console.cloud.google.com/apis/library/generativelanguage.googleapis.com
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# OAuth Redirect URI - MUST match what's configured in Google Cloud Console
# For local dev: http://localhost:3000/api/auth/gemini/callback
# For Vercel:    https://your-app-name.vercel.app/api/auth/gemini/callback
GEMINI_REDIRECT_URI=http://localhost:3000/api/auth/gemini/callback

# Gemini API Key (optional fallback if OAuth is not configured)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=
