# =============================================================================
# AgentForge - Environment Variables
# =============================================================================
# For Vercel deployment, add these in: Dashboard -> Settings -> Environment Variables
# =============================================================================

# Database (SQLite for development only)
DATABASE_URL=file:./db/custom.db

# ─── Google OAuth for Gemini Login (REQUIRED for web deployment) ─────────
#
# The Gemini CLI's built-in OAuth client only works with localhost.
# For web deployment (Vercel), you MUST create your own OAuth credentials:
#
# Step 1: Go to https://console.cloud.google.com/apis/credentials
# Step 2: Create a project (or select existing)
# Step 3: Click "Create Credentials" → "OAuth client ID"
#         - If prompted, configure "OAuth consent screen" first (External type is fine)
# Step 4: Select "Web application" as the application type
# Step 5: Under "Authorized redirect URIs", add:
#         https://YOUR-VERCEL-APP.vercel.app/api/auth/gemini/callback
# Step 6: Copy the Client ID and Client Secret below
# Step 7: Enable "Generative Language API" at:
#         https://console.cloud.google.com/apis/library/generativelanguage.googleapis.com
#
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# The redirect URI MUST match what you added in Google Cloud Console
# For local dev:  http://localhost:3000/api/auth/gemini/callback
# For Vercel:     https://YOUR-VERCEL-APP.vercel.app/api/auth/gemini/callback
GEMINI_REDIRECT_URI=http://localhost:3000/api/auth/gemini/callback
