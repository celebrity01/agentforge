# =============================================================================
# AgentForge - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these in the Vercel Dashboard -> Settings -> Environment Variables
# =============================================================================

# Database (SQLite for development)
DATABASE_URL=file:./db/custom.db

# ─── Google OAuth for Gemini Login ─────────────────────────────────────────
# NO SETUP REQUIRED! The app uses the Gemini CLI's built-in OAuth client
# by default. Just set the redirect URI for your deployment domain.
#
# Only set GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET if you want to use
# your own Google Cloud Console OAuth credentials instead.

# OAuth Redirect URI - MUST be set to match your deployment domain
# For local dev:    http://localhost:3000/api/auth/gemini/callback
# For Vercel:       https://your-app-name.vercel.app/api/auth/gemini/callback
GEMINI_REDIRECT_URI=http://localhost:3000/api/auth/gemini/callback

# Optional: Override with your own Google OAuth credentials
# GOOGLE_CLIENT_ID=your-google-client-id-here
# GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Optional: Gemini API key (fallback if OAuth is not working)
# GEMINI_API_KEY=
